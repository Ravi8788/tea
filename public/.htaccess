# Krushnai Amrutulya — Hostinger Apache (upload entire dist/ to public_html)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS (enable SSL in Hostinger hPanel first)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Skip real files and folders (images, assets, videos, css, js)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Astro folder routes: /about -> /about/index.html
  RewriteRule ^(.+?)/?$ $1/index.html [L]
</IfModule>

DirectoryIndex index.html

ErrorDocument 404 /404.html

# MIME types (videos for homepage hero)
<IfModule mod_mime.c>
  AddType video/mp4 .mp4
  AddType application/manifest+json .webmanifest
</IfModule>

# Cache static assets (Hostinger shared hosting)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 month"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

# Gzip (do not compress video)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json image/svg+xml
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
