---
import { company } from '../data/company';

const benefits = [
  { title: 'High Profit Margins', detail: 'Earn up to 35% margin on every sale' },
  { title: 'Priority Fast Delivery', detail: 'Orders dispatched within 48 hours' },
  { title: 'Full Marketing Support', detail: 'Digital assets, brochures & training provided' },
  { title: 'Premium Product Range', detail: 'Exclusive access to full catalog + new launches' },
  { title: 'Dedicated Business Manager', detail: 'Personal point of contact for your growth' },
  { title: 'Nationwide Distribution', detail: 'Join a network spanning 28+ states' },
];
---

<section class="dealer-program section-py relative overflow-hidden section-warm">
  <!-- Corner geometric decorations -->
  <div class="absolute top-0 left-0 w-48 h-48 opacity-10 pointer-events-none"
    style="background: linear-gradient(135deg, #C9A227 0%, transparent 60%);">
  </div>
  <div class="absolute bottom-0 right-0 w-48 h-48 opacity-10 pointer-events-none"
    style="background: linear-gradient(315deg, #C9A227 0%, transparent 60%);">
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full min-w-0">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center w-full min-w-0">

      <!-- Left: Benefits List -->
      <div class="min-w-0 w-full">
        <p class="label-text text-gold mb-3 reveal">Dealer Partner Program</p>
        <h2 class="text-display font-cinzel font-bold text-dark mb-6 reveal">
          Grow Your Business<br>
          <span class="text-gold-gradient">With Royal Chai</span>
        </h2>
        <p class="font-playfair italic text-dark/60 text-sub mb-10 reveal">
          Partner with Rajasthan's premium tea premix brand and unlock exclusive dealer benefits.
        </p>

        <ul class="space-y-5 stagger-group">
          {benefits.map(b => (
            <li class="stagger-child opacity-0 flex items-start gap-4 group">
              <!-- Gold checkmark -->
              <div class="mt-1 flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="10" cy="10" r="9" stroke="#C9A227" stroke-width="1.5"/>
                  <path d="M6 10 L9 13 L14 7" stroke="#C9A227" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="font-cinzel font-semibold text-gold text-sm">{b.title}</p>
                <p class="font-poppins text-dark/55 text-xs mt-0.5">{b.detail}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: CTA Card -->
      <div class="reveal-right min-w-0 w-full max-w-full">
        <div class="dealer-cta-card glass-card text-center border border-gold/25">
          <div class="ornament-divider mb-6 sm:mb-8">
            <span class="text-gold text-lg">✦</span>
          </div>

          <h3 class="dealer-cta-title font-cinzel font-bold text-dark mb-1">Become a</h3>
          <h3 class="dealer-cta-title-accent font-cinzel-deco font-bold text-gold-gradient mb-5 sm:mb-6">
            Dealer Partner
          </h3>

          <p class="dealer-cta-body font-poppins text-dark/60 text-sm mb-6 sm:mb-8 leading-relaxed">
            Join 50+ successful business partners across India who are earning
            with Krushnai Amrutulya's premium tea premix range.
          </p>

          <div class="flex flex-col gap-3 sm:gap-4 w-full">
            <a href="/contact" class="btn-gold dealer-cta-btn w-full max-w-full justify-center text-center">
              Apply Now — It's Free →
            </a>
            <a
              href={company.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline dealer-cta-btn w-full max-w-full justify-center text-center"
            >
              💬 WhatsApp Inquiry
            </a>
          </div>

          <div class="dealer-stats mt-6 sm:mt-8 pt-6 sm:pt-8 border-t border-gold/10">
            <div class="dealer-stat">
              <p class="font-cinzel font-bold text-gold text-lg sm:text-xl">Free</p>
              <p class="dealer-stat-label label-text text-dark/45 mt-1">Consultation</p>
            </div>
            <div class="dealer-stat">
              <p class="font-cinzel font-bold text-gold text-lg sm:text-xl">48hr</p>
              <p class="dealer-stat-label label-text text-dark/45 mt-1">Dispatch</p>
            </div>
            <div class="dealer-stat">
              <p class="font-cinzel font-bold text-gold text-lg sm:text-xl">35%</p>
              <p class="dealer-stat-label label-text text-dark/45 mt-1">Margin</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .dealer-cta-card {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: clamp(1.25rem, 5vw, 2.5rem);
  }

  .dealer-cta-title {
    font-size: clamp(1.25rem, 4.5vw, 1.5rem);
    line-height: 1.2;
  }

  .dealer-cta-title-accent {
    font-size: clamp(1.5rem, 6vw, 1.875rem);
    line-height: 1.15;
    word-break: break-word;
  }

  .dealer-cta-body {
    max-width: 22rem;
    margin-left: auto;
    margin-right: auto;
  }

  .dealer-cta-btn {
    white-space: normal;
    word-break: break-word;
    max-width: 100%;
    padding: 12px 16px;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    line-height: 1.35;
  }

  .dealer-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem 0.35rem;
    width: 100%;
    max-width: 100%;
  }

  .dealer-stat {
    min-width: 0;
    text-align: center;
    padding: 0 0.15rem;
  }

  .dealer-stat-label {
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    line-height: 1.3;
    hyphens: auto;
  }

  .dealer-stat + .dealer-stat {
    border-left: 1px solid rgba(201, 162, 39, 0.2);
  }

  @media (min-width: 480px) {
    .dealer-cta-btn {
      font-size: 0.75rem;
      padding: 14px 20px;
      letter-spacing: 0.08em;
    }

    .dealer-stat-label {
      font-size: 0.65rem;
      letter-spacing: 0.12em;
    }

    .dealer-stats {
      gap: 0.75rem 0.5rem;
    }
  }

  @media (min-width: 640px) {
    .dealer-cta-btn {
      font-size: 0.8rem;
    }
  }
</style>
