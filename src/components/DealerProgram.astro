---
import { company } from '../data/company';

const benefits = [
  { title: 'High Profit Margins', detail: 'Earn up to 35% margin on every sale' },
  { title: 'Priority Fast Delivery', detail: 'Orders dispatched within 48 hours' },
  { title: 'Full Marketing Support', detail: 'Digital assets, brochures & training provided' },
  { title: 'Premium Product Range', detail: 'Exclusive access to full catalog + new launches' },
  { title: 'Dedicated Business Manager', detail: 'Personal point of contact for your growth' },
  { title: 'Nationwide Distribution', detail: 'Join a network spanning 28+ states' },
];
---

<section class="section-py relative overflow-hidden section-warm">
  <!-- Corner geometric decorations -->
  <div class="absolute top-0 left-0 w-48 h-48 opacity-10"
    style="background: linear-gradient(135deg, #C9A227 0%, transparent 60%);">
  </div>
  <div class="absolute bottom-0 right-0 w-48 h-48 opacity-10"
    style="background: linear-gradient(315deg, #C9A227 0%, transparent 60%);">
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Benefits List -->
      <div>
        <p class="label-text text-gold mb-3 reveal">Dealer Partner Program</p>
        <h2 class="text-display font-cinzel font-bold text-dark mb-6 reveal">
          Grow Your Business<br>
          <span class="text-gold-gradient">With Royal Chai</span>
        </h2>
        <p class="font-playfair italic text-dark/60 text-sub mb-10 reveal">
          Partner with Rajasthan's premium tea premix brand and unlock exclusive dealer benefits.
        </p>

        <ul class="space-y-5 stagger-group">
          {benefits.map(b => (
            <li class="stagger-child opacity-0 flex items-start gap-4 group">
              <!-- Gold checkmark -->
              <div class="mt-1 flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="10" cy="10" r="9" stroke="#C9A227" stroke-width="1.5"/>
                  <path d="M6 10 L9 13 L14 7" stroke="#C9A227" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="font-cinzel font-semibold text-gold text-sm">{b.title}</p>
                <p class="font-poppins text-dark/55 text-xs mt-0.5">{b.detail}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: CTA Card -->
      <div class="reveal-right">
        <div class="glass-card p-10 text-center border border-gold/25">
          <div class="ornament-divider mb-8">
            <span class="text-gold text-lg">✦</span>
          </div>

          <h3 class="font-cinzel font-bold text-2xl text-dark mb-2">Become a</h3>
          <h3 class="font-cinzel-deco font-bold text-3xl text-gold-gradient mb-6">Dealer Partner</h3>

          <p class="font-poppins text-dark/60 text-sm mb-8 leading-relaxed">
            Join 50+ successful business partners across India who are earning
            with Krushnai Amrutulya's premium tea premix range.
          </p>

          <div class="flex flex-col gap-4">
            <a href="/contact" class="btn-gold w-full justify-center text-sm py-4">
              Apply Now — It's Free →
            </a>
            <a href={company.whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-outline w-full justify-center text-sm py-3.5">
              💬 WhatsApp Inquiry
            </a>
          </div>

          <div class="flex justify-center gap-8 mt-8 pt-8 border-t border-gold/10">
            <div class="text-center">
              <p class="font-cinzel font-bold text-gold text-xl">Free</p>
              <p class="label-text text-dark/45 text-xs mt-1">Consultation</p>
            </div>
            <div class="w-px bg-gold/20"></div>
            <div class="text-center">
              <p class="font-cinzel font-bold text-gold text-xl">48hr</p>
              <p class="label-text text-dark/45 text-xs mt-1">Dispatch</p>
            </div>
            <div class="w-px bg-gold/20"></div>
            <div class="text-center">
              <p class="font-cinzel font-bold text-gold text-xl">35%</p>
              <p class="label-text text-dark/45 text-xs mt-1">Margin</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
