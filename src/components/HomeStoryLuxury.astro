---
import { company } from '../data/company';

const storyPoints = [
  'Authentic Rajasthani chai profile with modern premix convenience.',
  'Crafted under strict hygiene and FSSAI-certified quality standards.',
  'Built to serve homes, hotels, cafes, and business partners across India.',
];
---

<section id="home-story" class="section-py home-story-luxury relative overflow-hidden">
  <div class="home-story-pattern absolute inset-0 mughal-texture" aria-hidden="true"></div>
  <div class="home-story-glow absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="home-story-panel grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="reveal order-2 lg:order-1">
        <p class="label-text text-gold mb-4">Our Story</p>
        <h2 class="text-display font-cinzel font-bold leading-tight text-dark mb-6">
          A Brand Born from
          <span class="text-gold-gradient block">Passion, Heritage & Purity</span>
        </h2>
        <div class="home-story-divider mb-6"></div>
        <div class="space-y-4 font-poppins text-sm md:text-base leading-relaxed text-dark/75">
          <p>
            Krushnai Amrutulya was founded by {company.founderName} in Rajasthan with one vision:
            preserve the soul of traditional chai and deliver that same rich taste in a premium, reliable premix.
          </p>
          <p>
            From carefully selected tea and spices to hygienic manufacturing and consistent flavour,
            every batch reflects our promise of quality in every cup.
          </p>
        </div>
        <ul class="mt-7 space-y-2.5">
          {storyPoints.map((point) => (
            <li class="flex items-start gap-2.5 font-poppins text-sm text-dark/80">
              <span class="text-gold flex-shrink-0 mt-0.5" aria-hidden="true">✦</span>
              {point}
            </li>
          ))}
        </ul>
        <a href="/about" class="btn-gold inline-flex mt-8 text-xs px-8 py-3.5">
          Read Full Story →
        </a>
      </div>

      <div class="reveal-right order-1 lg:order-2">
        <div class="home-story-image-shell">
          <div class="home-story-image-frame">
            <img
              src="/images/founder.png"
              alt={`${company.founderName}, Founder of Krushnai Amrutulya`}
              class="home-story-image"
              width="760"
              height="950"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="home-story-badge">
            <p class="font-cinzel-deco text-gold text-xl leading-none">Est. 2023</p>
            <p class="label-text text-dark/55 mt-1">Rajasthan, India</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-story-luxury {
    background: linear-gradient(180deg, #faf8f3 0%, #f5efe4 100%);
  }

  .home-story-pattern {
    opacity: 0.28;
  }

  .home-story-glow {
    background: radial-gradient(circle at 18% 20%, rgba(201, 162, 39, 0.14), transparent 52%);
    pointer-events: none;
  }

  .home-story-panel {
    padding: clamp(1rem, 1.8vw, 1.75rem);
    border: 1px solid rgba(201, 162, 39, 0.2);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(3px);
  }

  .home-story-divider {
    width: 68px;
    height: 2px;
    background: linear-gradient(90deg, #c9a227, rgba(201, 162, 39, 0.2));
  }

  .home-story-image-shell {
    position: relative;
  }

  .home-story-image-frame {
    position: relative;
    border: 1px solid rgba(201, 162, 39, 0.32);
    background: #fff;
    padding: 0.9rem;
    box-shadow: 0 24px 52px rgba(61, 41, 20, 0.14);
  }

  .home-story-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
  }

  .home-story-badge {
    position: absolute;
    left: -12px;
    bottom: -14px;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(201, 162, 39, 0.35);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    padding: 0.8rem 1rem;
  }

  @media (max-width: 767px) {
    .home-story-panel {
      padding: 1rem;
    }

    .home-story-image-frame {
      padding: 0.65rem;
    }

    .home-story-badge {
      left: 8px;
      bottom: 8px;
      padding: 0.6rem 0.75rem;
    }
  }
</style>
