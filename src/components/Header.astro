---
import { company } from '../data/company';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  const normalized = href.replace(/\/$/, '') || '/';
  return currentPath === normalized;
}
---

<style>
  #main-header {
    background: transparent;
    transition: background 0.4s ease, border-color 0.4s ease, backdrop-filter 0.4s ease;
  }
  #main-header.scrolled {
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201, 162, 39, 0.25);
    box-shadow: 0 4px 24px rgba(201, 162, 39, 0.08);
  }
  .nav-link {
    position: relative;
    color: rgba(30, 30, 30, 0.82);
    transition: color 0.3s ease;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--gold);
    transition: width 0.3s ease;
  }
  .nav-link:hover, .nav-link.active { color: var(--gold); }
  .nav-link:hover::after, .nav-link.active::after { width: 100%; }

  .site-logo {
    height: 3rem;
    width: auto;
    max-width: min(78vw, 16.5rem);
    object-fit: contain;
    object-position: left center;
    filter: drop-shadow(0 2px 10px rgba(0, 0, 0, 0.2));
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  @media (min-width: 768px) {
    .site-logo {
      height: 3.5rem;
      max-width: 18.5rem;
    }
  }
  a:hover .site-logo {
    filter: drop-shadow(0 4px 14px rgba(201, 162, 39, 0.25));
  }

  #mobile-menu {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    position: fixed;
    inset: 0;
    z-index: 998;
  }
</style>

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 px-6 lg:px-12 py-5">
  <div class="max-w-7xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center min-w-0 flex-shrink">
      <img
        src={company.logoHeaderPath}
        alt={`${company.brand} — Premium Jaggery Tea Premix`}
        class="site-logo"
        width="265"
        height="112"
        loading="eager"
        decoding="async"
        onerror="this.onerror=null;this.src='/images/logo.png'"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`nav-link font-poppins ${isActive(link.href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden lg:flex items-center gap-3">
      <a
        href={company.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-xs px-5 py-2.5"
      >
        💬 WhatsApp
      </a>
      <a href="/contact" class="btn-gold text-xs px-5 py-2.5">
        Get Quote →
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
      <span class="w-6 h-px bg-gold block"></span>
      <span class="w-4 h-px bg-gold block"></span>
      <span class="w-6 h-px bg-gold block"></span>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="hidden lg:hidden">
  {navLinks.map(link => (
    <a href={link.href} class="mobile-nav-link font-cinzel text-2xl text-dark hover:text-gold transition-colors tracking-widest uppercase">
      {link.label}
    </a>
  ))}
  <div class="flex flex-col gap-3 mt-4 w-48">
    <a href={company.whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-outline text-center text-sm">💬 WhatsApp</a>
    <a href="/contact" class="btn-gold text-center text-sm">Get Quote</a>
  </div>
</div>

<script>
  import '../scripts/nav.js';
</script>
