---
import { company } from '../data/company';

const heroSlides = [
	{
		label: 'Jaggery Cardamom',
		image: '/images/hero/hero-jaggery-cardamom.png',
		alt: 'Authentic Jaggery Cardamom Tea Premix promotional banner',
		href: '/products/jaggery-cardamom',
	},
	{
		label: 'Jaggery Basundi',
		image: '/images/hero/hero-jaggery-basundi.png',
		alt: 'Rich Jaggery Basundi Tea Premix promotional banner',
		href: '/products/jaggery-basundi',
	},
];

const heroVideoSrc = '/videos/advertisment.mp4';
const heroPoster = '/images/hero/hero-jaggery-cardamom.png';
---

<section class="home-hero">
	<div class="home-hero-bg" aria-hidden="true"></div>
	<div class="home-hero-pattern mughal-texture" aria-hidden="true"></div>
	<div class="home-hero-glow" aria-hidden="true"></div>

	<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-24 pb-14 sm:pt-28 sm:pb-20 lg:pt-32 lg:pb-24 w-full">
		<div class="home-hero-brand text-center lg:text-left mb-8 lg:mb-10 opacity-0">
			<p class="label-text text-gold mb-2 tracking-[0.25em]">{company.brand.toUpperCase()}</p>
			<p class="font-poppins text-sm text-dark/55">
				4 Premium Variants · FSSAI Certified · Pan India Delivery
			</p>
		</div>

		<!-- Banner slideshow -->
		<div class="swiper home-hero-swiper opacity-0">
			<div class="swiper-wrapper">
				{heroSlides.map((slide, index) => (
					<div class="swiper-slide">
						<div class="home-hero-slide w-full">
							<a href={slide.href} class="home-hero-image-frame block">
								<img
									src={slide.image}
									alt={slide.alt}
									class="home-hero-banner-img"
									width="1600"
									height="900"
									loading={index === 0 ? 'eager' : 'lazy'}
									decoding="async"
								/>
							</a>
						</div>
					</div>
				))}
			</div>

			<div class="home-hero-controls flex flex-col items-center gap-4 mt-8 sm:mt-10 lg:mt-12">
				<div class="home-hero-pagination flex flex-wrap justify-center gap-2"></div>
				<div class="home-hero-nav flex items-center gap-3">
					<button type="button" class="home-hero-prev" aria-label="Previous slide">←</button>
					<button type="button" class="home-hero-next" aria-label="Next slide">→</button>
				</div>
			</div>
		</div>

		<!-- Promotional video (below slideshow) -->
		<div class="home-hero-video-wrap opacity-0">
			<div class="home-hero-video-frame">
				<video
					class="home-hero-video"
					src={heroVideoSrc}
					poster={heroPoster}
					autoplay
					muted
					loop
					playsinline
					preload="auto"
					aria-label={`${company.brand} promotional video`}
				>
					Your browser does not support embedded video.
				</video>
			</div>
		</div>
	</div>

	<span class="home-hero-side hidden lg:block">SINCE 2023 · RAJASTHAN · INDIA</span>

	<div class="home-hero-scroll opacity-0">
		<span class="label-text text-gold/45 text-[10px]">Scroll to Discover</span>
		<div class="home-hero-scroll-line"></div>
	</div>
</section>

<script>
	import Swiper from 'swiper';
	import { Autoplay, Pagination, Navigation, EffectFade } from 'swiper/modules';
	import 'swiper/css';
	import 'swiper/css/pagination';
	import 'swiper/css/effect-fade';
	import { onAppReady } from '../scripts/ready.js';

	function initHomeHeroSwiper() {
		const el = document.querySelector('.home-hero-swiper');
		if (!el || el.dataset.swiperInit === 'true') return;

		const isMobile = window.matchMedia('(max-width: 767px)').matches;
		const slideNames = ['Jaggery Cardamom', 'Jaggery Basundi'];

		const swiper = new Swiper(el, {
			modules: [Autoplay, Pagination, Navigation, EffectFade],
			effect: isMobile ? 'slide' : 'fade',
			fadeEffect: { crossFade: true },
			slidesPerView: 1,
			loop: true,
			speed: isMobile ? 500 : 900,
			allowTouchMove: true,
			touchStartPreventDefault: false,
			touchMoveStopPropagation: false,
			passiveListeners: true,
			autoplay: {
				delay: 4500,
				disableOnInteraction: false,
				pauseOnMouseEnter: false,
			},
			pagination: {
				el: '.home-hero-pagination',
				clickable: true,
				renderBullet: (index, className) => {
					const label = slideNames[index] ?? 'Slide';
					return `<button type="button" class="${className} home-hero-dot" aria-label="${label}"><span class="home-hero-dot-label">${label}</span></button>`;
				},
			},
			navigation: { nextEl: '.home-hero-next', prevEl: '.home-hero-prev' },
			on: {
				init(sw) {
					el.dataset.swiperInit = 'true';
					sw.autoplay.start();
				},
			},
		});

		document.addEventListener('visibilitychange', () => {
			if (!document.hidden) swiper.autoplay.start();
		});
	}

	function initHeroVideo() {
		const video = document.querySelector('.home-hero-video');
		if (!video || video.dataset.heroVideoInit === 'true') return;

		video.dataset.heroVideoInit = 'true';

		const play = () => {
			const promise = video.play();
			if (promise && typeof promise.catch === 'function') {
				promise.catch(() => {});
			}
		};

		play();

		document.addEventListener('visibilitychange', () => {
			if (!document.hidden) play();
		});
	}

	onAppReady(() => {
		setTimeout(() => {
			initHomeHeroSwiper();
			initHeroVideo();
		}, 300);
	});
</script>

<script>
	import '../scripts/hero-animations.js';
</script>

<style>
	.home-hero {
		position: relative;
		min-height: auto;
		display: flex;
		align-items: center;
		overflow: visible;
		padding-bottom: 3rem;
	}

	@media (min-width: 768px) {
		.home-hero {
			min-height: auto;
			padding-bottom: 3rem;
		}
	}

	.home-hero-bg {
		position: absolute;
		inset: 0;
		background: var(--gradient-gold-soft);
	}

	.home-hero-pattern {
		position: absolute;
		inset: 0;
		opacity: 0.35;
	}

	.home-hero-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 55% 45% at 75% 45%, rgba(201, 162, 39, 0.14), transparent 70%);
		pointer-events: none;
	}

	.home-hero-slide {
		width: 100%;
	}

	.home-hero-swiper {
		width: 100%;
		overflow: hidden;
		touch-action: pan-y pinch-zoom;
	}

	.home-hero-swiper :global(.swiper-wrapper),
	.home-hero-swiper :global(.swiper-slide) {
		width: 100%;
	}

	.home-hero-image-frame {
		width: 100%;
		max-width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		margin: 0 auto;
		background: transparent;
		border: 1px solid rgba(201, 162, 39, 0.2);
		box-shadow: 0 14px 38px rgba(61, 41, 20, 0.16);
		transition: transform 0.35s ease, box-shadow 0.35s ease;
		overflow: hidden;
	}

	.home-hero-banner-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
	}

	.home-hero-image-frame:hover {
		transform: translateY(-2px);
		box-shadow: 0 24px 56px rgba(61, 41, 20, 0.2);
	}

	.home-hero-video-wrap {
		width: 100%;
		margin-top: 2rem;
	}

	@media (min-width: 768px) {
		.home-hero-video-wrap {
			margin-top: 2.5rem;
		}
	}

	.home-hero-video-frame {
		width: 100%;
		max-width: 100%;
		margin: 0 auto;
		border: 1px solid rgba(201, 162, 39, 0.28);
		box-shadow: 0 16px 48px rgba(61, 41, 20, 0.18);
		overflow: hidden;
		background: #1e1e1e;
		aspect-ratio: 16 / 9;
	}

	.home-hero-video {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.home-hero-prev,
	.home-hero-next {
		width: 44px;
		height: 44px;
		border: 1px solid rgba(201, 162, 39, 0.45);
		background: rgba(201, 162, 39, 0.08);
		color: #c9a227;
		font-size: 1.1rem;
		cursor: pointer;
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.home-hero-prev:hover,
	.home-hero-next:hover {
		background: rgba(201, 162, 39, 0.2);
		border-color: #c9a227;
	}

	@media (min-width: 1024px) {
		.home-hero-controls {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
			width: 100%;
		}
	}

	.home-hero-side {
		position: absolute;
		right: 24px;
		top: 50%;
		transform: translateY(-50%) rotate(90deg);
		font-size: 0.65rem;
		letter-spacing: 0.3em;
		color: rgba(201, 162, 39, 0.4);
		font-family: 'Poppins', sans-serif;
		font-weight: 500;
		white-space: nowrap;
	}

	.home-hero-scroll {
		position: absolute;
		bottom: 24px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.home-hero-scroll-line {
		width: 1px;
		height: 40px;
		background: linear-gradient(180deg, #c9a227, transparent);
		animation: homeScrollPulse 2s ease-in-out infinite;
	}

	@keyframes homeScrollPulse {
		0%, 100% { opacity: 0.5; transform: scaleY(1); }
		50% { opacity: 1; transform: scaleY(1.1); }
	}

	@media (max-width: 767px) {
		.home-hero-scroll {
			display: none !important;
		}

		.home-hero-brand {
			margin-bottom: 1.25rem;
		}

		.home-hero-video-frame {
			aspect-ratio: 9 / 16;
			max-height: min(72vh, 640px);
		}
	}
</style>
