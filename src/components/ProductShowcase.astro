---
import { products } from '../data/products';
import ProductImage from './ProductImage.astro';
---

<section id="products" class="section-py section-soft">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 reveal">
      <div>
        <p class="label-text text-gold mb-3">Our Collection</p>
        <h2 class="text-display font-cinzel font-bold text-dark">
          Signature <span class="text-gold-gradient">Tea Premixes</span>
        </h2>
      </div>
      <a href="/products" class="btn-outline text-xs px-6 py-3 self-start md:self-auto">
        View All Products →
      </a>
    </div>

    <div class="swiper product-swiper reveal">
      <div class="swiper-wrapper pb-14">
        {products.map((product, index) => (
          <div class="swiper-slide h-auto">
            <a href={`/products/${product.slug}`} class="product-card group block bg-white h-full shadow-sm hover:shadow-xl transition-shadow duration-300">
              <span class={`product-card-badge product-card-badge--${product.badgeVariant}`}>
                {product.badge}
              </span>
              <div class="product-card-image-wrap">
                <ProductImage
                  src={product.image}
                  alt={product.name}
                  class="product-card-image w-full h-full"
                  width={512}
                  height={341}
                  loading={index < 2 ? 'eager' : 'lazy'}
                />
              </div>
              <div class="p-5">
                <h3 class="font-cinzel font-bold text-sm uppercase tracking-wide mb-2 group-hover:text-gold transition-colors duration-300" style="color: #1E1E1E;">
                  {product.name}
                </h3>
                <p class="font-poppins text-xs leading-relaxed line-clamp-3 mb-4" style="color: rgba(30,30,30,0.72);">
                  {product.description}
                </p>
                <ul class="space-y-1.5">
                  {product.highlights.slice(0, 3).map(h => (
                    <li class="flex items-center gap-2 font-poppins text-[11px]" style="color: rgba(30,30,30,0.8);">
                      <span class="flex-shrink-0 w-1.5 h-1.5 rotate-45" style="background: #C9A227;"></span>
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            </a>
          </div>
        ))}
      </div>
      <div class="swiper-button-prev product-prev"></div>
      <div class="swiper-button-next product-next"></div>
      <div class="swiper-pagination product-pagination"></div>
    </div>

  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Pagination, Navigation, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';
  import 'swiper/css/navigation';
  import { onAppReady } from '../scripts/ready.js';

  onAppReady(() => {
    const el = document.querySelector('.product-swiper');
    if (!el || el.dataset.swiperInit === 'true') return;

    new Swiper(el, {
      modules: [Pagination, Navigation, Autoplay],
      slidesPerView: 1,
      spaceBetween: 20,
      touchStartPreventDefault: false,
      touchMoveStopPropagation: false,
      autoplay: { delay: 3500, disableOnInteraction: false },
      pagination: { el: '.product-pagination', clickable: true },
      navigation: { nextEl: '.product-next', prevEl: '.product-prev' },
      breakpoints: {
        640: { slidesPerView: 2, spaceBetween: 24 },
        1024: { slidesPerView: 3, spaceBetween: 28 },
        1280: { slidesPerView: 4, spaceBetween: 32 },
      },
      on: {
        init() {
          el.dataset.swiperInit = 'true';
        },
      },
    });
  });
</script>

<style>
  .product-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(201, 162, 39, 0.12);
  }

  .product-card-badge {
    display: block;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.5rem 0.75rem;
  }

  .product-card-badge--est-seller {
    background: #1a3a2a;
    color: #faf8f3;
  }

  .product-card-badge--customer-favorite {
    background: #c9a227;
    color: #1e1e1e;
  }

  .product-card-badge--premium-blend {
    background: #c4848e;
    color: #1e1e1e;
  }

  .product-card-badge--signature {
    background: #3d2914;
    color: #c9a227;
  }

  .product-card-image-wrap {
    aspect-ratio: 3 / 2;
    background: #faf8f3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0.5rem;
    overflow: hidden;
  }

  .product-card-image-wrap :global(.product-img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center;
    transform: none;
  }

  .product-card:hover .product-card-image-wrap :global(.product-img) {
    transform: scale(1.03);
    transition: transform 0.5s ease;
  }

  .product-swiper :global(.swiper-pagination-bullet) {
    background: #C9A227;
    opacity: 0.35;
  }
  .product-swiper :global(.swiper-pagination-bullet-active) {
    opacity: 1;
  }
  .product-swiper :global(.swiper-button-prev),
  .product-swiper :global(.swiper-button-next) {
    color: #C9A227;
    transform: scale(0.7);
  }
  .product-swiper :global(.swiper-button-prev::after),
  .product-swiper :global(.swiper-button-next::after) {
    font-size: 1.2rem;
  }

  .product-swiper {
    touch-action: pan-y pinch-zoom;
  }

  @media (max-width: 639px) {
    .product-swiper :global(.swiper-button-prev),
    .product-swiper :global(.swiper-button-next) {
      display: none;
    }

    .product-swiper {
      padding-bottom: 0.5rem;
    }
  }
</style>
