---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { seoPages } from '../data/seo';
---

<BaseLayout
  title={seoPages.notFound.title}
  description={seoPages.notFound.description}
  keywords={seoPages.notFound.keywords}
  noindex={true}
>
  <Header />
  <main class="min-h-[70vh] flex items-center justify-center section-soft section-py pt-32">
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="label-text text-gold mb-4">404</p>
      <h1 class="text-display font-cinzel font-bold text-dark mb-6">Page Not Found</h1>
      <p class="font-poppins text-dark/60 mb-10">
        This page may have moved or no longer exists. Explore our products or contact us for help.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-gold text-xs px-8 py-3.5">Back to Home</a>
        <a href="/products" class="btn-outline text-xs px-8 py-3.5">View Products</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
