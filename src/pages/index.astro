---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import BrandHeritage from '../components/BrandHeritage.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import TeaJourney from '../components/TeaJourney.astro';
import StatsSection from '../components/StatsSection.astro';
import Testimonials from '../components/Testimonials.astro';
import DealerProgram from '../components/DealerProgram.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { seoPages } from '../data/seo';
import { organizationSchema, webSiteSchema, localBusinessSchema } from '../lib/seo';
---

<BaseLayout
  title={seoPages.home.title}
  description={seoPages.home.description}
  keywords={seoPages.home.keywords}
  canonicalPath="/"
  schema={[organizationSchema(), webSiteSchema(), localBusinessSchema()]}
>
  <Header />
  <main>
    <HeroSection />
    <ProductShowcase />
    <BrandHeritage />
    <WhyChooseUs />
    <TeaJourney />
    <StatsSection />
    <Testimonials />
    <DealerProgram />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
