---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import HomePremiumShowcase from '../components/HomePremiumShowcase.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import HomeStoryTimelineLuxury from '../components/HomeStoryTimelineLuxury.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import TeaJourney from '../components/TeaJourney.astro';
import StatsSection from '../components/StatsSection.astro';
import Testimonials from '../components/Testimonials.astro';
import DealerProgram from '../components/DealerProgram.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { seoPages } from '../data/seo';
import {
  organizationSchema,
  webSiteSchema,
  localBusinessSchema,
  homePageSchema,
  heroVideoSchema,
  faqSchema,
  homeFaqItems,
  combineSchemas,
} from '../lib/seo';
---

<BaseLayout
  title={seoPages.home.title}
  description={seoPages.home.description}
  keywords={seoPages.home.keywords}
  canonicalPath="/"
  ogImage="/og-image.jpg"
  schema={combineSchemas(
    organizationSchema(),
    webSiteSchema(),
    localBusinessSchema(),
    homePageSchema(),
    heroVideoSchema(),
    faqSchema(homeFaqItems),
  )}
>
  <Header />
  <main>
    <HeroSection />
    <HomePremiumShowcase />
    <ProductShowcase />
    <HomeStoryTimelineLuxury />
    <WhyChooseUs />
    <TeaJourney />
    <StatsSection />
    <Testimonials />
    <DealerProgram />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
