---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { company } from '../data/company';
import { seoPages } from '../data/seo';
import {
  aboutPageSchema,
  breadcrumbSchema,
  organizationSchema,
  localBusinessSchema,
} from '../lib/seo';

const introBullets = [
  'Premium Quality Assured',
  'Authentic Rajasthani Taste',
  'Organic Spice Blends',
  'Hygienic Manufacturing',
  'All India Delivery',
  'Affordable Luxury',
];

const timeline = [
  {
    year: '2022 – THE IDEA',
    title: 'A Vision Takes Shape',
    detail:
      'Inspired by authentic Rajasthani tea traditions, Vinod Parihar began conceptualising a premium instant chai premix honouring the taste without sacrificing convenience.',
  },
  {
    year: '2023 – LAUNCH',
    title: 'Shree Krishna Enterprises Founded',
    detail:
      'Krushnai Amrutulya launched with a commitment to quality manufacturing, authentic recipes, and nationwide distribution to bring the best of Rajasthani chai to India.',
  },
  {
    year: '2023–24 – GROWTH',
    title: 'All India Expansion',
    detail:
      'Rapid expansion across 28+ states, building a partner network and achieving 500+ happy customers through consistent quality, reliability, and heartfelt flavour.',
  },
  {
    year: '2025 ONWARDS',
    title: "India's Most Trusted Chai Brand",
    detail:
      "On the path to becoming India's foremost premium tea premix brand — expanding product lines, deepening distribution, and elevating every everyday chai experience.",
  },
];

const whyChooseFeatures = [
  {
    icon: '☕',
    title: 'Luxury Tea Experience',
    description:
      'Premium café-quality taste delivered instantly — elevating the everyday chai ritual into an indulgence.',
  },
  {
    icon: '🌿',
    title: 'Organic Spices',
    description:
      'Finest organic cardamom, ginger, clove, and cinnamon — sourced from trusted farms for an authentically aromatic blend.',
  },
  {
    icon: '🏺',
    title: 'Authentic Rajasthani Taste',
    description:
      'Recipes rooted in Rajasthani chai tradition — preserved in every sachet for an unmistakably genuine flavour.',
  },
  {
    icon: '🚚',
    title: 'All India Delivery',
    description:
      'Serving 28+ states with fast, reliable logistics so your premium chai reaches you on time, every time.',
  },
  {
    icon: '💎',
    title: 'Affordable Luxury',
    description:
      'Premium quality at respectful prices — because great chai should be a pleasure for everyone, not a privilege for few.',
  },
  {
    icon: '🏭',
    title: 'Hygienic Manufacturing',
    description:
      'State-of-the-art, food-grade certified facility ensuring every batch meets the highest safety and purity standards.',
  },
  {
    icon: '🌱',
    title: 'Premium Ingredients',
    description:
      'Only highest-grade tea leaves and natural herbs are selected, ensuring superior flavour, colour, and aroma in every cup.',
  },
  {
    icon: '⚡',
    title: 'Instant Preparation',
    description:
      'Ready in 60 seconds — no brewing, no measuring. Perfect for homes, offices, canteens, and bulk service operations.',
  },
];

const premiumIngredients = [
  {
    name: 'Elaichi (Cardamom)',
    image: '/images/ingredients/cardamom.jpg',
    body: 'Green cardamom from Kerala adds floral sweetness and a warm aromatic finish to every cup.',
  },
  {
    name: 'Adrak (Ginger)',
    image: '/images/ingredients/ginger.jpg',
    body: 'Dried Sonth ginger delivers robust warmth and aiding digestion with that signature bold chai kick.',
  },
  {
    name: 'Chai Patta (Tea)',
    image: '/images/ingredients/tea-leaves.jpg',
    body: 'Premium CTC Assam tea leaves form the rich, malty base giving every cup its deep colour and body.',
  },
  {
    name: 'Laung (Clove)',
    image: '/images/ingredients/clove.jpg',
    body: 'Handpicked cloves add deep complexity and a subtle intensity that makes our blend unmistakably distinct.',
  },
  {
    name: 'Dalchini (Cinnamon)',
    image: '/images/ingredients/cinnamon.jpg',
    body: 'Ceylon cinnamon adds warmth and a gentle spiced sweetness that perfectly rounds out the masala profile.',
  },
  {
    name: 'Jadi Booti (Herbs)',
    image: '/images/ingredients/herbs.jpg',
    body: 'A secret blend of traditional Ayurvedic herbs elevating the nutritional profile and enhancing wellbeing.',
  },
];

const qualityProcessSteps = [
  {
    icon: '🌿',
    title: 'Ingredient Selection',
    body: 'Only premium, organic-grade spices and tea leaves pass our stringent sourcing criteria.',
  },
  {
    icon: '🔬',
    title: 'Quality Testing',
    body: 'Each batch undergoes rigorous lab testing for purity, potency, and safety compliance.',
  },
  {
    icon: '🏭',
    title: 'Hygienic Manufacturing',
    body: 'Produced in a state-of-the-art food-grade certified manufacturing facility.',
  },
  {
    icon: '📦',
    title: 'Precision Packaging',
    body: 'Sealed in airtight, freshness-preserving packaging to lock in every note of flavour.',
  },
  {
    icon: '🚚',
    title: 'Pan India Distribution',
    body: 'Efficient logistics network ensures timely delivery to 28+ states across India.',
  },
  {
    icon: '❤️',
    title: 'Customer Satisfaction',
    body: 'Continuous feedback loops refine our product to always exceed expectations.',
  },
];

const stats = [
  { number: 500, suffix: '+', label: 'Happy Customers' },
  { number: 50, suffix: '+', label: 'Business Partners' },
  { number: 28, suffix: '+', label: 'States Served' },
  { number: 100, suffix: '%', label: 'Quality Commitment' },
];
---

<BaseLayout
  title={seoPages.about.title}
  description={seoPages.about.description}
  keywords={seoPages.about.keywords}
  canonicalPath="/about/"
  schema={[
    organizationSchema(),
    localBusinessSchema(),
    aboutPageSchema(),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'About Us', path: '/about/' },
    ]),
  ]}
>

  <Header />
  <main class="overflow-x-hidden">

    <!-- Section 1 — Hero Banner -->
    <section class="about-hero relative overflow-hidden">
      <div class="absolute inset-0 about-hero-bg"></div>
      <div class="absolute inset-0 about-hero-overlay"></div>
      <div class="absolute inset-0 mughal-texture about-hero-pattern"></div>

      <!-- Breadcrumb -->
      <nav class="about-breadcrumb absolute z-20 left-4 sm:left-6 md:left-8 lg:left-12 font-poppins text-xs reveal" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold transition-colors duration-300 text-dark/45">Home</a>
        <span class="mx-2 text-dark/25">/</span>
        <span style="color: #C9A227;">About Us</span>
      </nav>

      <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 text-center reveal">
        <p class="label-text text-gold mb-4 md:mb-5">About Us</p>
        <h1 class="font-cinzel-deco about-hero-title font-black text-gold-gradient mb-5 md:mb-6 leading-tight">
          Krushnai Amrutulya
        </h1>
        <div class="ornament-divider max-w-xs mx-auto mb-5 md:mb-6">
          <span class="text-gold">✦</span>
        </div>
        <p class="font-playfair italic text-sub max-w-2xl mx-auto text-dark/70">
          Our Story · Our Heritage · Our Promise
        </p>
      </div>
    </section>

    <!-- Section 2 — About Intro -->
    <section id="about-intro" class="section-py relative" style="background: #FAF8F3;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.4), transparent);"></div>
      <div class="max-w-7xl mx-auto px-6">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- LEFT — Founder Image (above text on mobile) -->
          <div class="reveal-left order-1 lg:order-1">
            <div class="founder-image-wrap relative">
              <div class="founder-image-frame overflow-hidden">
                <img
                  src="/images/founder.png"
                  alt="Vinod Parihar wearing traditional Rajasthani safa, holding Krushnai Amrutulya product boxes"
                  class="founder-image-img"
                  width="800"
                  height="1000"
                  loading="eager"
                />
                <span class="founder-est-badge font-poppins font-medium text-xs tracking-wide">Est. 2023</span>
              </div>
            </div>
            <p class="founder-image-caption font-poppins font-medium text-xs text-center mt-4" style="color: #C9A227;">
              Vinod Parihar — Founder & Managing Director
            </p>
          </div>

          <!-- RIGHT — Text Content -->
          <div class="reveal-right order-2 lg:order-2">
            <p class="label-text text-gold mb-4">About Krushnai Amrutulya</p>
            <h2 class="text-display font-cinzel font-bold mb-4 leading-tight" style="color: #1E1E1E;">
              A Brand Born from<br>
              <span class="text-gold-gradient">Passion & Heritage</span>
            </h2>
            <div class="about-intro-underline mb-8"></div>

            <div class="about-intro-stagger space-y-6 font-poppins text-sm md:text-base font-normal" style="color: #1E1E1E; line-height: 1.75;">
              <p class="about-intro-para">
                Krushnai Amrutulya is a premium tea premix brand under <span class="text-gold font-medium">Shree Krishna Enterprises</span>,
                founded by <span class="text-gold font-medium">Vinod Parihar</span> in 2023 — with a singular vision to bring the authentic taste
                of Rajasthani chai to every corner of India, with the convenience of a modern premix.
              </p>
              <p class="about-intro-para">
                The name "<span class="text-gold font-medium italic">Amrutulya</span>" translates to "<span class="text-gold font-medium italic">equivalent to nectar</span>" — a promise upheld in every blend.
                Our formulas capture the warmth of handcrafted chai: bold tea liquor, fragrant spices,
                and the perfect balance of sweetness that defines Indian hospitality.
              </p>
              <p class="about-intro-para">
                From our hygienic manufacturing facility to your cup, every step is executed with
                uncompromising care — ensuring consistent flavour, freshness, and quality in every serving.
              </p>
            </div>

            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 mt-12">
              {introBullets.map((item) => (
                <li class="flex items-center gap-3 font-poppins text-sm font-medium" style="color: #1E1E1E; line-height: 1.75;">
                  <span class="flex-shrink-0 text-gold text-xs" aria-hidden="true">✦</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Section 3 — Our Story + Timeline -->
    <section id="about-story" class="section-py relative overflow-hidden" style="background: #F0EBE0;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.35), transparent);"></div>
      <div class="relative z-10 max-w-7xl mx-auto px-6">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

          <!-- LEFT — Story Text -->
          <div class="reveal-left">
            <p class="label-text text-gold mb-4">Our Story</p>
            <h2 class="text-display font-cinzel font-bold mb-4 leading-tight" style="color: #1E1E1E;">
              Rooted in Rajasthan,<br>
              <span class="text-gold-gradient">Brewed for Bharat</span>
            </h2>
            <div class="about-intro-underline mb-8"></div>

            <div class="space-y-7 font-poppins text-sm md:text-base font-normal" style="color: #1E1E1E; line-height: 1.75;">
              <p>
                Every great brand begins with an honest memory. For Vinod Parihar, it was the memory
                of steaming glasses of chai served at roadside dhabas in Rajasthan — fragrant with
                cardamom, bold with ginger, and sweetened just right — a daily ritual shared by millions.
              </p>
              <p>
                As urbanisation accelerated and lifestyles became busier, that ritual was at risk.
                The artisanal knowledge of perfectly spiced chai was being lost to convenience. Vinod
                saw not a problem, but an opportunity: to preserve authenticity while making it accessible
                to everyone, everywhere, instantly.
              </p>
              <p>
                Thus Krushnai Amrutulya was born — a bridge between the timeless and the modern.
                Every sachet carries the soul of Rajasthan's chai culture, crafted through meticulous
                recipe development and the finest organic spices.
              </p>
            </div>
          </div>

          <!-- RIGHT — Vertical Timeline -->
          <div class="story-timeline relative reveal-right" id="story-timeline">
            <div class="story-timeline-track" id="story-timeline-track" aria-hidden="true"></div>
            <div class="story-timeline-nodes">
              {timeline.map((item, i) => (
                <div
                  class="story-timeline-node group flex gap-5 cursor-pointer"
                  data-index={i}
                >
                  <div class="story-timeline-dot-wrap flex-shrink-0">
                    <div class="story-timeline-dot"></div>
                  </div>
                  <div class="story-timeline-content pb-8">
                    <p class="story-timeline-year">{item.year}</p>
                    <h3 class="story-timeline-title">{item.title}</h3>
                    <p class="story-timeline-desc">{item.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Section 4 — Founder's Message -->
    <section id="founder-message" class="section-py relative overflow-hidden founder-message-section">
      <div class="absolute inset-0 founder-message-gradient"></div>
      <div class="absolute inset-0 mughal-texture founder-message-pattern"></div>

      <div class="relative z-10 max-w-[800px] mx-auto px-6 text-center">

        <p class="label-text text-gold mb-4 founder-message-label opacity-0">Founder's Message</p>
        <h2 class="font-cinzel font-semibold mb-8 founder-message-heading opacity-0 text-dark text-2xl">
          Words from the Visionary
        </h2>
        <div class="ornament-divider max-w-xs mx-auto mb-12 founder-message-divider opacity-0">
          <span class="text-gold">✦</span>
        </div>

        <div class="founder-quote-block relative text-left mx-auto opacity-0">
          <span class="founder-quote-deco font-cinzel-deco select-none" aria-hidden="true">❝</span>
          <blockquote class="founder-quote-text">
            <p>
              In Rajasthan, chai is not just a beverage — it is an emotion, a welcome, a moment
              of pause in a hectic day. When I founded Krushnai Amrutulya, my goal was simple:
              to bottle that emotion. To create a product where every cup tastes like it was lovingly
              brewed by someone who truly cares. We use organic spices, follow hygienic processes,
              and obsess over consistency — because our customers deserve nothing less than the best.
              India deserves a tea premix brand that is truly world-class, and that is exactly what
              we are building, one cup at a time.
            </p>
          </blockquote>
        </div>

        <footer class="founder-message-attribution mt-12 opacity-0">
          <div class="w-12 h-px mx-auto mb-6" style="background: #C9A227;"></div>
          <img
            src="/images/founder-avatar.jpg"
            alt="Vinod Parihar"
            class="founder-avatar mx-auto mb-4"
            width="144"
            height="144"
            loading="lazy"
          />
          <p class="font-cinzel font-semibold text-lg" style="color: #C9A227;">Vinod Parihar</p>
          <p class="font-poppins text-[13px] italic mt-2 text-dark/60">
            Founder & Managing Director, Shree Krishna Enterprises
          </p>
        </footer>

      </div>
    </section>

    <!-- Section 5 — Vision & Mission -->
    <section id="vision-mission" class="section-py relative" style="background: #FAF8F3;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.35), transparent);"></div>
      <div class="max-w-6xl mx-auto px-6">

        <div class="text-center mb-14 md:mb-16 reveal">
          <p class="label-text text-gold mb-4">Our Purpose</p>
          <h2 class="text-display font-cinzel font-bold leading-tight" style="color: #1E1E1E;">
            Vision & <span class="text-gold-gradient">Mission</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
          <!-- Vision -->
          <article class="reveal purpose-card">
            <div class="purpose-card-accent"></div>
            <div class="purpose-card-inner">
              <div class="purpose-card-icon" aria-hidden="true">🔭</div>
              <p class="label-text text-gold mb-4">Our Vision</p>
              <p class="font-poppins font-normal text-sm md:text-base" style="color: #1E1E1E; line-height: 1.75;">
                To become India's most trusted and beloved premium tea premix brand —
                a name synonymous with authentic flavour, consistent quality, and the warmth
                of traditional Indian hospitality, accessible to every household across the nation.
              </p>
            </div>
          </article>
          <!-- Mission -->
          <article class="reveal purpose-card">
            <div class="purpose-card-accent"></div>
            <div class="purpose-card-inner">
              <div class="purpose-card-icon" aria-hidden="true">🎯</div>
              <p class="label-text text-gold mb-4">Our Mission</p>
              <p class="font-poppins font-normal text-sm md:text-base" style="color: #1E1E1E; line-height: 1.75;">
                To deliver authentic, consistent, and delightful tea experiences through
                innovative premix technology, premium organic ingredients, hygienic
                manufacturing, and an unwavering commitment to customer satisfaction.
              </p>
            </div>
          </article>
        </div>

      </div>
    </section>

    <!-- Section 6 — Why Choose Us -->
    <section id="why-choose" class="section-py relative section-soft">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.35), transparent);"></div>
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-14 md:mb-16 reveal">
          <p class="label-text text-gold mb-4">Our Difference</p>
          <h2 class="text-display font-cinzel font-bold text-dark">
            Why Choose <span class="text-gold-gradient">Krushnai Amrutulya</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6 stagger-group">
          {whyChooseFeatures.map((feature) => (
            <article class="stagger-child why-choose-card opacity-0 group">
              <div class="why-choose-icon text-[48px] leading-none mb-5" aria-hidden="true">{feature.icon}</div>
              <div class="why-choose-line mb-4"></div>
              <h3 class="font-cinzel font-semibold text-base mb-2.5" style="color: #C9A227;">{feature.title}</h3>
              <p class="font-poppins font-normal text-[13px] text-dark/65" style="line-height: 1.65;">
                {feature.description}
              </p>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- Section 7 — Premium Ingredients -->
    <section id="premium-ingredients" class="section-py relative" style="background: #FAF8F3;">
      <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(201,162,39,0.35), transparent);"></div>
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-14 md:mb-16 reveal">
          <p class="label-text text-gold mb-4">Our Secret</p>
          <h2 class="text-display font-cinzel font-bold mb-5" style="color: #1E1E1E;">
            Premium <span class="text-gold-gradient">Ingredients</span>
          </h2>
          <p class="font-poppins font-normal text-sm md:text-base max-w-[520px] mx-auto" style="color: rgba(30,30,30,0.6);">
            Every ingredient is carefully selected from the finest sources across India
            to deliver an unmatchable taste profile in every cup.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 stagger-group">
          {premiumIngredients.map((ingredient) => (
            <article class="stagger-child ingredient-card opacity-0 group">
              <div class="ingredient-image-wrap overflow-hidden">
                <img
                  src={ingredient.image}
                  alt={ingredient.name}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  width="400"
                  height="300"
                  loading="lazy"
                />
              </div>
              <div class="ingredient-card-body">
                <h3 class="ingredient-card-name">{ingredient.name}</h3>
                <p class="ingredient-card-desc">{ingredient.body}</p>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- Section 8 — Quality Process -->
    <section id="quality-process" class="section-py relative overflow-hidden" style="background: #F0EBE0;">
      <div class="max-w-7xl mx-auto px-6">

        <div class="text-center mb-14 md:mb-16 reveal">
          <p class="label-text text-gold mb-4">Our Standards</p>
          <h2 class="text-display font-cinzel font-bold" style="color: #1E1E1E;">
            The Quality <span class="text-gold-gradient">Process</span>
          </h2>
        </div>

        <!-- Desktop: horizontal 6 steps -->
        <div class="hidden lg:block quality-process-desktop relative">
          <div class="quality-process-line-h" id="quality-process-line-h" aria-hidden="true"></div>
          <div class="grid grid-cols-6 gap-3">
            {qualityProcessSteps.map((step, i) => (
              <div class="quality-step text-center px-1">
                <div class="quality-step-circle mx-auto mb-4">
                  <span aria-hidden="true">{step.icon}</span>
                </div>
                <p class="quality-step-num">{String(i + 1).padStart(2, '0')}</p>
                <h3 class="quality-step-title">{step.title}</h3>
                <p class="quality-step-desc">{step.body}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Mobile / tablet: vertical -->
        <div class="lg:hidden quality-process-mobile relative">
          <div class="quality-process-line-v" id="quality-process-line-v" aria-hidden="true"></div>
          <div class="space-y-8">
            {qualityProcessSteps.map((step, i) => (
              <div class="quality-step-mobile flex gap-5 items-start">
                <div class="flex flex-col items-center flex-shrink-0">
                  <div class="quality-step-circle quality-step-circle-sm">
                    <span aria-hidden="true">{step.icon}</span>
                  </div>
                </div>
                <div class="pt-1">
                  <p class="quality-step-num text-left mb-1">{String(i + 1).padStart(2, '0')}</p>
                  <h3 class="quality-step-title text-left mb-2">{step.title}</h3>
                  <p class="quality-step-desc text-left">{step.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Section 9 — Stats Counter -->
    <section id="about-stats" class="section-py relative overflow-hidden about-stats-section">
      <div class="absolute inset-0 about-stats-gradient"></div>
      <div class="absolute inset-0 about-stats-glow"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6">

        <div class="text-center mb-14 md:mb-16 reveal">
          <p class="label-text text-gold mb-4">Our Numbers</p>
          <h2 class="text-display font-cinzel font-bold text-dark">
            Growth That <span class="text-gold-gradient">Speaks For Itself</span>
          </h2>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
          {stats.map((stat) => (
            <div class="about-stat-item text-center reveal">
              <span
                class="stat-number about-stat-number font-cinzel font-black text-gold leading-none"
                data-target={stat.number}
                data-suffix={stat.suffix}
              >
                0{stat.suffix}
              </span>
              <div class="about-stat-separator mx-auto my-4"></div>
              <p class="about-stat-label font-cinzel font-normal uppercase">
                {stat.label}
              </p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Section 10 — Final CTA Banner -->
    <section id="final-cta" class="section-py relative overflow-hidden section-warm">
      <div class="absolute inset-0 final-cta-stripe" aria-hidden="true"></div>
      <div class="relative z-10 max-w-3xl mx-auto px-6 text-center reveal">

        <h2 class="font-cinzel font-bold leading-tight mb-6 final-cta-heading">
