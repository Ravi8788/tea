<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initStoryTimeline() {
    const section = document.getElementById('about-story');
    const track = document.getElementById('story-timeline-track');
    const nodes = document.querySelectorAll('.story-timeline-node');
    if (!section || !track || !nodes.length) return;

    gsap.to(track, {
      scaleY: 1,
      duration: 1.4,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        toggleActions: 'play none none none',
      },
    });

    gsap.to(nodes, {
      opacity: 1,
      x: 0,
      duration: 0.7,
      stagger: 0.25,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#story-timeline',
        start: 'top 78%',
        toggleActions: 'play none none none',
      },
    });

    nodes.forEach((node, i) => {
      node.addEventListener('mouseenter', () => {
        nodes.forEach((n, j) => n.classList.toggle('active', j === i));
      });
      node.addEventListener('click', () => {
        nodes.forEach((n, j) => n.classList.toggle('active', j === i));
      });
    });
    nodes[0]?.classList.add('active');
  }

  function initFounderMessage() {
    const section = document.getElementById('founder-message');
    if (!section) return;

    const label = section.querySelector('.founder-message-label');
    const heading = section.querySelector('.founder-message-heading');
    const divider = section.querySelector('.founder-message-divider');
    const deco = section.querySelector('.founder-quote-deco');
    const quote = section.querySelector('.founder-quote-block');
    const attribution = section.querySelector('.founder-message-attribution');

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 78%',
        toggleActions: 'play none none none',
      },
    });

    if (label) tl.to(label, { opacity: 1, duration: 0.5, ease: 'power2.out' });
    if (heading) tl.to(heading, { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.3');
    if (divider) tl.to(divider, { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.3');
    if (deco) {
      tl.fromTo(deco, { opacity: 0, scale: 0.8 }, { opacity: 0.15, scale: 1, duration: 0.8, ease: 'power2.out' }, '-=0.2');
    }
    if (quote) {
      tl.fromTo(quote, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.5');
    }
    if (attribution) {
      tl.fromTo(attribution, { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.3');
    }
  }

  function initQualityProcess() {
    const section = document.getElementById('quality-process');
    const lineH = document.getElementById('quality-process-line-h');
    const lineV = document.getElementById('quality-process-line-v');
    if (!section) return;

    if (lineH) {
      gsap.to(lineH, {
        scaleX: 1,
        duration: 1.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          toggleActions: 'play none none none',
        },
      });
    }

    if (lineV) {
      gsap.to(lineV, {
        scaleY: 1,
        duration: 1.4,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 75%',
          toggleActions: 'play none none none',
        },
      });
    }

    const steps = section.querySelectorAll('.quality-step, .quality-step-mobile');
    if (steps.length) {
      gsap.fromTo(steps,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.12,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 78%',
            toggleActions: 'play none none none',
          },
        }
      );
    }
  }

  function initIntroStagger() {
    const paras = document.querySelectorAll('#about-intro .about-intro-para');
    if (!paras.length) return;

    gsap.to(paras, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#about-intro .about-intro-stagger',
        start: 'top 82%',
        toggleActions: 'play none none none',
      },
    });
  }

  function initAboutPage() {
    initStoryTimeline();
    initFounderMessage();
    initIntroStagger();
    initQualityProcess();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutPage);
  } else {
    initAboutPage();
  }
</script>
